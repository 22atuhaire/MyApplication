<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">


    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/collector_registration"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/green_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <!-- ScrollView for form (in case content is long) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tvHeader"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmit"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/green_primary"
                app:strokeWidth="1dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/full_name"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="272dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@color/gray_light"
                        android:hint="@string/full_name_hint"
                        android:textColorHint="@color/hint_text"
                        android:inputType="textPersonName|textCapWords"
                        android:importantForAutofill="no"
                        android:padding="16dp"
                        android:textSize="16sp" />

                    <!-- Phone Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone_number"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="272dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@color/gray_light"
                        android:hint="@string/phone_hint"
                        android:textColorHint="@color/hint_text"
                        android:importantForAutofill="no"
                        android:inputType="phone"
                        android:padding="16dp"
                        android:textSize="16sp" />

                    <!-- Email (Optional) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/email"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="276dp"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@color/gray_light"
                        android:hint="@string/email_hint"
                        android:textColorHint="@color/hint_text"
                        android:importantForAutofill="no"
                        android:inputType="textEmailAddress"
                        android:padding="16dp"
                        android:textSize="16sp" />

                    <!-- Vehicle Type -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vehicle_type"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerVehicle"
                        android:layout_width="275dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="24dp"
                        android:background="@color/gray_light"
                        android:padding="16dp" />

                    <!-- Upload ID Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/upload_id"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="12dp" />

                    <!-- Upload Front -->
                    <TextView
                        android:id="@+id/btnUploadFront"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/upload_border"
                        android:clickable="true"
                        android:contentDescription="@string/desc_upload_front"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:text="@string/upload_front"
                        android:textColor="@color/green_primary"
                        android:textSize="16sp" />

                    <!-- Upload Back -->
                    <TextView
                        android:id="@+id/btnUploadBack"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="@string/upload_back"
                        android:textSize="16sp"
                        android:textColor="@color/green_primary"
                        android:gravity="center"
                        android:background="@drawable/upload_border"
                        android:layout_marginBottom="16dp"
                        android:contentDescription="@string/desc_upload_back"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Terms Checkbox -->
                    <CheckBox
                        android:id="@+id/cbTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/terms_text"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:contentDescription="@string/desc_terms"
                        android:layout_marginBottom="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Submit Button -->
    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="293dp"
        android:layout_height="79dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/green_primary"
        android:enabled="false"
        android:text="@string/submit_for_approval"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvLoginLink"
        tools:layout_editor_absoluteX="43dp" />

    <!-- Login Link -->
    <TextView
        android:id="@+id/tvLoginLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/already_have_account"
        android:textSize="14sp"
        android:textColor="@color/gray_dark"
        android:minHeight="48dp"
        android:gravity="center"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>