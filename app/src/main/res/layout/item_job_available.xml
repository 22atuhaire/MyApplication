<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/green_primary"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Food Type and Distance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvFoodType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mixed_food"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/distance_0_8_km"
                android:textSize="14sp"
                android:textColor="@color/green_primary"
                android:background="@color/light_green_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />
        </LinearLayout>

        <!-- Quantity -->
        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/_2_5_kg"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="4dp" />

        <!-- Time Posted -->
        <TextView
            android:id="@+id/tvTimePosted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/posted_5_min_ago"
            android:textSize="14sp"
            android:textColor="@color/gray_dark"
            android:layout_marginBottom="12dp" />

        <!-- View Button -->
        <Button
            android:id="@+id/btnViewJob"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/view_button"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="@color/green_primary"
            app:cornerRadius="20dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>