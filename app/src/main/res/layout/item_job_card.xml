<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/green_primary"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Food Icon -->
        <TextView
            android:id="@+id/tvFoodIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/food_icon"
            android:textSize="24sp"
            android:gravity="center"
            android:background="@color/gray_light"
            android:layout_marginEnd="12dp" />

        <!-- Job Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFoodType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mixed_food"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_0_8_km_2_5_kg"
                android:textSize="14sp"
                android:textColor="@color/gray_dark"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvTimeAgo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/posted_5_min_ago"
                android:textSize="12sp"
                android:textColor="@color/gray_dark"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- View Button -->
        <TextView
            android:id="@+id/btnView"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/view_button"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/green_primary"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
