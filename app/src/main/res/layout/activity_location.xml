<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <!-- Progress Indicator -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/step_3_of_4"
        android:textSize="14sp"
        android:textColor="@color/gray_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/where_pickup"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@+id/tvProgress"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <!-- ScrollView for content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tvHeader"
        app:layout_constraintBottom_toTopOf="@+id/btnContinue"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/location_details_form"
        android:importantForAccessibility="yes">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Map Preview Card (Placeholder) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/gray_light"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/map"
                        android:textSize="48sp" />

                    <TextView
                        android:id="@+id/tvUseCurrentLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:text="@string/use_current_location"
                        android:textColor="@color/green_primary"
                        android:textSize="14sp"
                        android:minWidth="48dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Manual Address Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/green_primary"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/or_enter_address"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="16dp" />

                    <!-- Street Address Label -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/address_line1"
                        android:textSize="12sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="8dp" />

                    <!-- EditText with proper width constraints -->
                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="4dp"
                        android:hint="@string/address_line1_hint"
                        android:inputType="textPostalAddress"
                        android:background="@color/gray_light"
                        android:padding="16dp"
                        android:autofillHints="address"
                        android:importantForAutofill="yes"
                        android:textColor="@color/black"
                        android:textColorHint="@color/hint_text" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- Instructions Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/green_primary"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pickup_instructions"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:hint="@string/instructions_hint"
                        android:textSize="14sp"
                        android:background="@color/gray_light"
                        android:gravity="top"
                        android:padding="16dp"
                        android:inputType="textMultiLine"
                        android:autofillHints="no"
                        android:importantForAutofill="no"
                        android:textColor="@color/black"
                        android:textColorHint="@color/hint_text" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Address Checkbox -->
            <CheckBox
                android:id="@+id/cbSaveAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save_address"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp"
                android:minHeight="48dp"
                android:paddingHorizontal="8dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

    <!-- Continue Button -->
    <Button
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/continue_button"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/green_primary"
        app:cornerRadius="24dp"
        android:paddingHorizontal="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>