<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <!-- Top Bar with Back Button -->
    <LinearLayout
        android:id="@+id/llTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/back"
            android:textSize="16sp"
            android:textColor="@color/green_primary"
            android:gravity="center_vertical"
            android:minWidth="48dp"
            android:paddingEnd="16dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            tools:ignore="RtlSymmetry" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Active Job Badge -->
        <TextView
            android:id="@+id/tvActiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/active_job_badge"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@color/green_primary"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- ScrollView for content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/llTopBar"
        app:layout_constraintBottom_toTopOf="@+id/llButtons"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Job Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardJobInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/light_green_bg"
                android:layout_marginBottom="16dp"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFoodType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mixed_food"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/green_primary"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvQuantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quantity_2_5_kg"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDonorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/donor_sarah_4_9"
                        android:textSize="16sp"
                        android:textColor="@color/black" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pickup Location Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/green_primary"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pickup_address"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_123_main_street_apt_4b"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/kampala_uganda"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvInstructions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ring_doorbell_back_door"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:layout_marginBottom="16dp" />

                    <!-- Directions Button -->
                    <Button
                        android:id="@+id/btnDirections"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/get_directions"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/gray_light"
                        android:textColor="@color/green_primary"
                        app:cornerRadius="24dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Donor Contact Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/green_primary"
                app:strokeWidth="1dp"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/donor_contact"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray_dark"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvDonorPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/_256_712_345_678"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnCallDonor"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="@string/call_donor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/green_primary"
            app:cornerRadius="16dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnMarkCollected"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="@string/mark_collected"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/white"
            android:textColor="@color/green_primary"
            app:cornerRadius="16dp"
            app:strokeColor="@color/green_primary"
            app:strokeWidth="2dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>